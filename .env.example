# Pennypacker Configuration
# Copy to .env and fill in values

# Empower login URL (default works for most accounts)
EMPOWER_LOGIN_URL=https://ira.empower-retirement.com/participant/#/sfd-login?accu=MYERIRA
EMPOWER_DASHBOARD_URL=https://ira.empower-retirement.com/dashboard/#/user/home

# Zillow property URL for home value (find your property page on zillow.com)
# ZILLOW_PROPERTY_URL=https://www.zillow.com/homedetails/your-address/zpid/

# Database path (relative to project root)
DB_PATH=data/pennypacker.db

# Cookie storage path
COOKIE_PATH=cookies.json

# Scraper settings
HEADLESS=false

# Chrome path (auto-detected if not set; useful for WSL)
# CHROME_PATH=/usr/bin/google-chrome
